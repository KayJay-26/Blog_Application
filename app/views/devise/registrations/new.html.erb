<div class="auth-container">

  <span class="hero-tag">GET STARTED</span>

  <h1 class="auth-title">Join<br><span style="color: #d4f13a;">BlogPulse.</span></h1>
  <p class="auth-sub">Create your account and start sharing stories that matter.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

    <%# Validation errors %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <%= f.label :username, "Username", class: "form-label" %>
      <%= f.text_field :username,
            autofocus: true,
            placeholder: "how you'll appear to others",
            autocomplete: "username" %>
    </div>

    <div class="field">
      <%= f.label :email, "Email Address", class: "form-label" %>
      <%= f.email_field :email,
            placeholder: "you@example.com",
            autocomplete: "email" %>
    </div>

    <div class="field">
      <%= f.label :password, "Password", class: "form-label" %>
      <% if @minimum_password_length %>
        <span class="auth-hint">At least <%= @minimum_password_length %> characters</span>
      <% end %>
      <%= f.password_field :password,
            placeholder: "••••••••",
            autocomplete: "new-password" %>
    </div>

    <div class="field">
      <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
      <%= f.password_field :password_confirmation,
            placeholder: "••••••••",
            autocomplete: "new-password" %>
    </div>

    <div class="actions">
      <%= f.submit "Create Account →" %>
    </div>

  <% end %>

  <div class="auth-divider">
    <span>already have an account?</span>
  </div>

  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>

</div>