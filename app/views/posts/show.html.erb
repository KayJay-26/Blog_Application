<div class="post-show">

  <% if notice.present? %>
    <p class="notice"><%= notice %></p>
  <% end %>

  <% if @post.cover_image.attached? %>
<div class="post-cover">
  <%= image_tag @post.cover_image, class: "post-cover-image" %>
</div>
  <% end %>

  <article class="post-content">

    <h1 class="post-heading">
      <%= @post.title %>
    </h1>

    <div class="post-meta">
      By
      <%= link_to @post.user.username,
            profile_path(@post.user),
            class: "author-link" %>

      •

      <%= @post.created_at.strftime("%B %Y") %>
    </div>

    <div class="post-body">
      <%= simple_format(@post.body) %>
    </div>

  </article>

  <hr class="post-divider">

  <section class="comments-section">

    <h2>Comments</h2>

    <% @post.comments.each do |comment| %>

      <div class="comment-card">

        <div class="comment-author">
          <%= link_to comment.user.username,
                profile_path(comment.user),
                class: "author-link" %>
        </div>

        <p>
          <%= comment.body %>
        </p>

        <% if comment.user == current_user %>
          <%= button_to "Delete",
                post_comment_path(@post, comment),
                method: :delete,
                class: "delete-btn" %>
        <% end %>

      </div>

    <% end %>

  </section>

  <% if user_signed_in? %>

    <section class="comment-form">

      <h3>Add a Comment</h3>

      <%= form_with model: [@post, Comment.new] do |form| %>

        <%= form.text_area :body,
              rows: 4,
              placeholder: "Share your thoughts..." %>

        <%= form.submit "Post Comment" %>

      <% end %>

    </section>

  <% else %>

    <p>
      Please
      <%= link_to "log in", new_user_session_path %>
      to comment.
    </p>

  <% end %>

  <div class="post-actions">

    <% if @post.user == current_user %>

      <%= link_to "Edit Post",
            edit_post_path(@post),
            class: "read-link" %>

      <%= button_to "Delete Post",
            @post,
            method: :delete,
            class: "delete-btn" %>

    <% end %>

    <%= link_to "← Back to Posts",
          posts_path,
          class: "read-link" %>

  </div>

</div>