<div class="post-show">

  <%# Cover Image %>
  <% if @post.cover_image.attached? %>
    <div class="post-cover">
      <%= image_tag @post.cover_image, class: "post-cover-image" %>
    </div>
  <% end %>

  <%# Post Header %>
  <article class="post-content">
    <div class="post-tags-row">
      <span class="hero-tag">BLOGPULSE</span>
      <span style="color: #444; font-size: 12px;"><%= @post.created_at.strftime("%B %d, %Y") %></span>
    </div>

    <h1 class="post-heading"><%= @post.title %></h1>

    <div class="post-meta">
      <div class="post-meta-author">
        <span class="author-dot"></span>
        By <%= link_to (@post.user.username.presence || @post.user.email),
                  profile_path(@post.user),
                  class: "author-link" %>
      </div>
      <div class="post-meta-right">
        <span>❤️ <%= @post.likes.count %> <%= "like".pluralize(@post.likes.count) %></span>
        <span>💬 <%= @post.comments.count %> <%= "comment".pluralize(@post.comments.count) %></span>
      </div>
    </div>

    <div class="post-body">
      <%= simple_format(@post.body) %>
    </div>

    <%# Like Button %>
    <div class="post-likes">
      <% if user_signed_in? %>
        <% if @post.likes.exists?(user: current_user) %>
          <%= button_to post_like_path(@post), method: :delete, class: "like-btn like-btn-active" do %>
            ❤️ Unlike
          <% end %>
        <% else %>
          <%= button_to post_like_path(@post), method: :post, class: "like-btn" do %>
            🤍 Like this post
          <% end %>
        <% end %>
      <% end %>
      <span class="like-count">❤️ <%= @post.likes.count %> <%= "like".pluralize(@post.likes.count) %></span>
    </div>

    <%# Owner Actions %>
    <% if @post.user == current_user %>
      <div class="post-owner-actions">
        <%= link_to "✏️ Edit Post", edit_post_path(@post), class: "hero-cta" %>
        <%= button_to "🗑 Delete Post", @post, method: :delete, class: "delete-btn-pill",
              data: { turbo_confirm: "Are you sure you want to delete this post?" } %>
      </div>
    <% end %>
  </article>

  <hr class="post-divider">

  <%# Comments Section %>
  <section class="comments-section">
    <h2>
      Comments
      <span class="comment-count-badge"><%= @post.comments.count %></span>
    </h2>

    <% if @post.comments.empty? %>
      <div class="empty-comments">
        <p>No comments yet. Be the first to share your thoughts.</p>
      </div>
    <% else %>
      <% @post.comments.order(created_at: :desc).each do |comment| %>
        <div class="comment-card">
          <div class="comment-header">
            <div class="comment-author">
              <span class="author-dot"></span>
              <%= link_to (comment.user.username.presence || comment.user.email),
                    profile_path(comment.user),
                    class: "author-link" %>
            </div>
            <div class="comment-meta-right">
              <span class="comment-date"><%= comment.created_at.strftime("%b %d, %Y") %></span>
              <% if comment.user == current_user %>
                <%= button_to "✕",
                      post_comment_path(@post, comment),
                      method: :delete,
                      class: "comment-delete-btn",
                      data: { turbo_confirm: "Delete this comment?" } %>
              <% end %>
            </div>
          </div>
          <p class="comment-body"><%= comment.body %></p>
        </div>
      <% end %>
    <% end %>

    <%# Comment Form %>
    <% if user_signed_in? %>
      <section class="comment-form">
        <h3>Leave a Comment</h3>
        <%= form_with model: [@post, Comment.new] do |form| %>
          <%= form.text_area :body,
                rows: 4,
                placeholder: "Share your thoughts..." %>
          <div class="comment-submit">
            <%= form.submit "Post Comment" %>
          </div>
        <% end %>
      </section>
    <% else %>
      <div class="login-prompt">
        <p>
          <%= link_to "Log in", new_user_session_path %> or
          <%= link_to "sign up", new_user_registration_path %> to join the conversation.
        </p>
      </div>
    <% end %>
  </section>

  <%# Back Link %>
  <div class="post-back">
    <%= link_to "← Back to Posts", posts_path, class: "read-link" %>
  </div>

</div>