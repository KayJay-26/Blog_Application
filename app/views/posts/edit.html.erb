<% content_for :title, "Edit Post" %>

<div class="post-form-page">

  <div class="post-form-header">
    <span class="hero-tag">EDITING</span>
    <h1 class="post-form-title">
      Refine Your<br>
      <span style="color: #d4f13a;">Story.</span>
    </h1>
    <p class="post-form-sub">Make it even better than before.</p>
  </div>

  <%= render "form", post: @post %>

  <div class="post-form-back" style="display: flex; gap: 20px; margin-top: 32px;">
    <%= link_to "← View Post", @post, class: "read-link" %>
    <%= link_to "← All Posts", posts_path, class: "read-link" %>
  </div>

</div>