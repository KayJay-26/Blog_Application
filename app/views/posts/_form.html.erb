<%= form_with(model: post) do |form| %>

  <%# Error messages %>
  <% if post.errors.any? %>
    <div class="form-errors">
      <p class="form-errors-title">
        <%= pluralize(post.errors.count, "error") %> prevented this post from saving:
      </p>
      <ul>
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Title %>
  <div class="form-group">
    <%= form.label :title, "Post Title", class: "form-label" %>
    <%= form.text_field :title,
          placeholder: "Give your post a great title...",
          class: "form-input" %>
  </div>

  <%# Cover Image %>
  <div class="form-group">
    <%= form.label :cover_image, "Cover Image", class: "form-label" %>
    <div class="file-upload-area">
      <%= form.file_field :cover_image, class: "file-input", accept: "image/*" %>
      <div class="file-upload-label">
        <span class="file-upload-icon">📷</span>
        <span class="file-upload-text">Click to upload a cover image</span>
        <span class="file-upload-hint">PNG, JPG, WEBP recommended</span>
      </div>
    </div>

    <%# Show existing cover image when editing %>
    <% if post.persisted? && post.cover_image.attached? %>
      <div class="current-cover">
        <p class="form-label" style="margin-bottom: 8px;">Current Cover</p>
        <%= image_tag post.cover_image, class: "current-cover-img" %>
      </div>
    <% end %>
  </div>

  <%# Body %>
  <div class="form-group">
    <%= form.label :body, "Your Story", class: "form-label" %>
    <%= form.textarea :body,
          placeholder: "Write something worth reading...",
          class: "form-textarea",
          rows: 14 %>
  </div>

  <%# Submit %>
  <div class="form-submit">
    <%= form.submit post.persisted? ? "💾 Save Changes" : "🚀 Publish Post",
          class: "form-submit-btn" %>
    <%= link_to "Cancel", posts_path, class: "hero-cta", style: "margin-left: 12px;" %>
  </div>

<% end %>