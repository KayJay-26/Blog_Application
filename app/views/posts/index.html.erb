<div class="hero">
  <div class="hero-left">
    <span class="hero-tag">BLOGPULSE</span>

    <h1 class="hero-title">
      Write.<br>
      Read.<br>
      <span class="alt">Connect.</span>
    </h1>

    <p class="hero-sub">
      Share your thoughts, ideas, and stories with a community that values authentic perspectives.
    </p>

    <%= link_to "Start Writing", new_post_path, class: "hero-cta" %>
  </div>

  <div class="hero-right">
    <div class="blob blob1"></div>
    <div class="blob blob2"></div>
    <div class="blob blob3"></div>
  </div>
</div>

<section class="exp">
  <div class="exp-header">
    <h2><u>Latest Stories</u></h2>
    <h3>Discover what the BlogPulse community is writing about.</h3>
  </div>

  <div class="cards">
    <% @posts.each do |post| %>
      <div class="card">
        <div class="card-body">
          <div class="author">
            <span class="author-dot"></span>
            <span><%= post.user.username %></span>
          </div>

          <h3 class="post-title">
            <%= truncate(post.title, length: 40) %>
          </h3>

          <p class="post-excerpt">
            <%= truncate(post.body, length: 120) %>
          </p>

          <%= link_to "Read →", post, class: "read-link" %>
        </div>
      </div>
    <% end %>
  </div>
</section>