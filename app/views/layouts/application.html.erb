<!DOCTYPE html>
<html>
  <head>
    <title>BlogPulse</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>

    <nav class="nav">
      <div class="nav-logo">BlogPulse</div>

      <div class="nav-links">
        <span>Explore</span>
        <span>About</span>

        <% if user_signed_in? %>

          <span>
            <%= current_user.username.presence || current_user.email %>
          </span>

          <%= button_to "Logout",
                destroy_user_session_path,
                method: :delete,
                class: "nav-btn" %>
<% else %>

  <%= link_to "Sign Up",
        new_user_registration_path,
        class: "nav-btn" %>

<% end %>
      </div>
    </nav>

    <%= yield %>

  </body>
</html>