<!DOCTYPE html>
<html>
  <head>
    <title>BlogPulse</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>

    <nav class="nav">
      <div class="nav-logo"><%= link_to "BlogPulse", root_path, style: "color: inherit; text-decoration: none;" %></div>

      <div class="nav-links">
        <%= link_to "Explore", posts_path, style: "color: #aaa; text-decoration: none;" %>
        <%= link_to "About", "#", style: "color: #aaa; text-decoration: none;" %>

        <% if user_signed_in? %>
          <%= link_to "✍️ New Post", new_post_path, class: "nav-btn", style: "margin-right: 4px;" %>

          <span style="color: #aaa; font-size: 13px;">
            <%= current_user.username.presence || current_user.email %>
          </span>

          <%= button_to "Logout",
                destroy_user_session_path,
                method: :delete,
                class: "nav-btn",
                style: "background: transparent; border: 1px solid #333; color: #aaa;" %>
        <% else %>
          <%= link_to "Login", new_user_session_path, style: "color: #aaa; text-decoration: none; font-size: 13px;" %>
          <%= link_to "Sign Up", new_user_registration_path, class: "nav-btn" %>
        <% end %>
      </div>
    </nav>

    <%# ── Flash messages ── %>
    <% if notice.present? %>
      <div class="flash flash-notice"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="flash flash-alert"><%= alert %></div>
    <% end %>

    <%= yield %>

    <footer class="footer">
      <div>
        <div class="footer-logo">BlogPulse</div>
        <p>A space for ideas, stories,<br>and perspectives.</p>
      </div>
      <div>
        <h4>NAVIGATE</h4>
        <ul>
          <li><%= link_to "Explore Posts", posts_path, style: "color: #555; text-decoration: none;" %></li>
          <% if user_signed_in? %>
            <li><%= link_to "New Post", new_post_path, style: "color: #555; text-decoration: none;" %></li>
          <% else %>
            <li><%= link_to "Sign Up", new_user_registration_path, style: "color: #555; text-decoration: none;" %></li>
            <li><%= link_to "Login", new_user_session_path, style: "color: #555; text-decoration: none;" %></li>
          <% end %>
        </ul>
      </div>
      <div>
        <h4>BLOGPULSE</h4>
        <p>Built with Ruby on Rails.<br>Dark. Fast. Minimal.</p>
      </div>
    </footer>

    <div class="footer-bottom">
      © <%= Time.current.year %> BlogPulse. All rights reserved.
    </div>

  </body>
</html>